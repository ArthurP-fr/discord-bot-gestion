    "express": "^4.21.2",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "next": "15.5.15",
    "pg": "^8.13.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
